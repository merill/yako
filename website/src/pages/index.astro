---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const features = [
  {
    label: 'Your new tab',
    title: 'Your favorite Microsoft apps, front and center',
    description: 'Replace your browser\'s cluttered new tab with a clean, beautiful start page. Pin shortcuts to Outlook, OneDrive, Copilot, Loop, To Do, and any app you use daily.',
    image: '/landing/feature-1.webp',
    alt: 'Yako new tab page with Microsoft app shortcuts',
  },
  {
    label: 'Add portals',
    title: 'Right-click. Search. Add. Done.',
    description: 'Right-click anywhere on your new tab page and browse 900+ Microsoft portals, blades, and admin centers. Search by name, pick the ones you need, and they appear on your start page instantly.',
    image: '/landing/feature-2.mp4',
    alt: 'Right-click menu opening the portal search dialog',
    video: true,
  },
  {
    label: 'No more clutter',
    title: 'Take back your new tab from clickbait and ads',
    description: 'Edge and Chrome fill your new tab with sponsored content, clickbait news, and ads you never asked for. Worse, they make it nearly impossible to set a custom page. Yako replaces all of that with a clean start page you actually control.',
    image: '/landing/feature-3.webp',
    alt: 'Comparison of cluttered browser new tab vs clean Yako page',
  },
  {
    label: 'MSPortals.io view',
    title: 'MSPortals.io, right in your browser',
    description: 'Love msportals.io? Set it as your default new tab view and get the full searchable directory of every Microsoft admin portal you already know and love.',
    image: '/landing/feature-4.webp',
    alt: 'MSPortals.io directory view as default new tab',
  },
  {
    label: 'cmd.ms view',
    title: 'For the keyboard warriors',
    description: 'Set cmd.ms as your default view and jump to any Microsoft portal or blade without reaching for the mouse. Type a shortcut, press Enter, and you are there.',
    image: '/landing/feature-5.webp',
    alt: 'cmd.ms command-line interface for portal shortcuts',
  },
  {
    label: 'Backgrounds & clock',
    title: 'A clean new tab that feels like home',
    description: 'Set solid colors, local images, or videos as your background. Add a digital or analog clock with world time zones, personalized greetings, and a Markdown notes widget.',
    image: '/landing/feature-6.webp',
    alt: 'New tab page with custom background, clock, and world time zones',
  },
]

const miniFeatures = [
  {
    title: 'Dark mode',
    description: 'Automatic dark mode that follows your system preference, or set it manually.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>',
  },
  {
    title: 'Notes widget',
    description: 'Built-in Markdown notes with headings, lists, and checkboxes. Always one tab away.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8Z"/><path d="M15 3v4a2 2 0 0 0 2 2h4"/></svg>',
  },
  {
    title: 'World clocks',
    description: 'Add clocks for multiple time zones. 12 or 24 hour format, seconds, analog faces.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
  },
  {
    title: 'Save settings',
    description: 'Export and import your configuration to keep your setup safe or move it to another device.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>',
  },
  {
    title: 'Keyboard-first',
    description: 'Tab to search, type to filter, Enter to open. Fast navigation without the mouse.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2"/><path d="M6 8v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/><line x1="8" x2="8" y1="12" y2="12"/><line x1="12" x2="12" y1="12" y2="12"/><line x1="16" x2="16" y1="12" y2="12"/><line x1="10" x2="14" y1="16" y2="16"/></svg>',
  },
  {
    title: 'Drag & drop layout',
    description: 'Rearrange widgets on the page. Adjust width, spacing, and element order.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>',
  },
]

const faqs = [
  {
    q: 'Is Yako free?',
    a: 'Yes, Yako is completely free and open source under the GPL-3.0 license. No account, no subscription, no strings attached.',
  },
  {
    q: 'Does Yako collect any data?',
    a: 'No. Yako collects no data, has no account system, and requires only the storage permission.',
  },
  {
    q: 'What browsers does Yako support?',
    a: 'Yako supports Microsoft Edge, Google Chrome, and Firefox. It also works on Chromium-based browsers like Brave and Vivaldi.',
  },
  {
    q: 'Where does the portal data come from?',
    a: 'Portal data is sourced from two community projects: merill/cmd (cmd.ms shortcuts) and msportals.io. The extension fetches the latest data from their GitHub repositories to keep portals up to date.',
  },
  {
    q: 'Is Yako a Microsoft product?',
    a: 'No. Yako is not a Microsoft product or service. It is an independent, community-driven open source project built by Microsoft community members.',
  },
]
---

<Base title="Yako - A beautiful browser start page for Microsoft users and admins">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "Yako",
          "url": "https://getyako.com",
          "description": "A beautiful browser start page for Microsoft users and admins. Instantly access 900+ Microsoft portals and blades right from your new tab page.",
        },
        {
          "@type": "SoftwareApplication",
          "name": "Yako",
          "applicationCategory": "BrowserApplication",
          "operatingSystem": "Windows, macOS, Linux",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
          "description": "A beautiful browser start page for Microsoft users and admins. Instantly access 900+ Microsoft portals and blades right from your new tab page.",
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a },
          })),
        },
      ],
    })} />
  </Fragment>
  <Nav slot="nav" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-bg" id="hero-bg" style="background-image: url('/landing/hero-bg.webp');">
        <div class="hero-overlay" id="hero-overlay"></div>
        <div class="hero-fade"></div>

        <div class="hero-card" id="hero-card">
          <!-- Selection rectangle -->
          <div class="hero-select-rect" id="hero-rect"></div>
          <!-- Fake cursor -->
          <div class="hero-cursor" id="hero-cursor">
            <svg height="48" width="48" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" style="filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3))">
              <g fill="none" fill-rule="evenodd" transform="translate(10 7)">
                <path d="m6.148 18.473 1.863-1.003 1.615-.839-2.568-4.816h4.332l-11.379-11.408v16.015l3.316-3.221z" fill="#fff"/>
                <path d="m6.431 17 1.765-.941-2.775-5.202h3.604l-8.025-8.043v11.188l2.53-2.442z" fill="#000"/>
              </g>
            </svg>
          </div>

          <h1>New tab. Supercharged.</h1>
          <p class="hero-sub">
            A beautiful browser start page for Microsoft users and admins. Instantly access 900+ Microsoft portals and blades right from your new tab page.
          </p>

          <div class="hero-actions">
            <a href="/docs/install/" class="btn btn-primary">
              <img src="/icons/edge.svg" alt="" width="18" height="18" />
              Add to Edge
            </a>
            <a href="/docs/install/" class="btn btn-primary">
              <img src="/icons/chrome.svg" alt="" width="18" height="18" />
              Add to Chrome
            </a>
            <a href="/docs/install/" class="btn btn-primary">
              <img src="/icons/firefox.svg" alt="" width="18" height="18" />
              Add to Firefox
            </a>
          </div>

          <p class="hero-trust">Free &middot; Open source &middot; No data collection</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (alternating 2-col) -->
  <section class="features" id="features">
    <div class="container">
      {features.map((feature, i) => (
        <div class:list={['feature-row', { 'feature-row-reverse': i % 2 === 1 }]}>
          <div class="feature-text">
            <p class="feature-label">{feature.label}</p>
            <h2>{feature.title}</h2>
            <p class="feature-desc">{feature.description}</p>
          </div>
          <div class="feature-image">
            {feature.video ? (
              <video src={feature.image} autoplay loop muted playsinline />
            ) : (
              <img src={feature.image} alt={feature.alt} loading="lazy" />
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Mini features grid -->
  <section class="mini-features">
    <div class="container">
      <div class="mini-features-header">
        <h2>And a whole lot more</h2>
        <p>Small details that make a big difference.</p>
      </div>
      <div class="mini-grid">
        {miniFeatures.map(f => (
          <div class="mini-cell">
            <div class="mini-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="testimonial-section">
    <div class="container">
      <div class="testimonial-bg" style="background-image: url('/landing/testimonial-bg.webp');">
        <div class="testimonial-card">
          <blockquote>
            &ldquo;Yako turns my new tab into a real productivity tool.
            Every Microsoft portal I need is just a keystroke away.&rdquo;
          </blockquote>
          <p class="testimonial-attr">A happy Microsoft admin</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Built on Bonjourr -->
  <section class="bonjourr-section">
    <div class="container bonjourr-inner">
      <h2>Built on Bonjourr</h2>
      <p>
        Yako is a fork of <a href="https://bonjourr.fr" rel="noreferrer noopener">Bonjourr</a>,
        a beautiful open source new tab extension created by
        <strong>Victor Azevedo</strong> and <strong>Tahoe Beetschen</strong>.
        We built on their excellent foundation to add Microsoft portal search, catalog integration,
        and admin-focused features.
      </p>
      <p>
        Bonjourr is a fantastic project on its own. If you enjoy Yako, please consider
        supporting the original Bonjourr project too &mdash; star their repo, contribute code,
        or spread the word.
      </p>
      <div class="bonjourr-actions">
        <a href="https://bonjourr.fr" class="btn btn-secondary" rel="noreferrer noopener">
          Visit bonjourr.fr
        </a>
        <a href="https://github.com/victrme/Bonjourr" class="btn btn-secondary" rel="noreferrer noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Star Bonjourr on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Aussie Powered -->
  <section class="aussie-section">
    <div class="container aussie-inner">
      <h2>🦘 Aussie powered</h2>
      <p class="aussie-subtitle">Yako is built on the shoulders of two brilliant Australian open source projects.</p>
      <div class="aussie-grid">
        <a href="https://github.com/adamfowlerit/msportals.io" class="aussie-card" rel="noreferrer noopener">
          <div class="aussie-card-header">
            <img src="https://msportals.io/favicon.ico" alt="" width="32" height="32" class="aussie-logo" />
            <h3>msportals.io</h3>
          </div>
          <p>
            Thanks to the collaboration with <strong>Adam Fowler</strong>, the full msportals.io directory
            is available right inside the extension as a new tab view.
          </p>
          <span class="aussie-link">View on GitHub &rarr;</span>
        </a>
        <a href="https://github.com/loryanstrant/MicrosoftCloudLogos" class="aussie-card" rel="noreferrer noopener">
          <div class="aussie-card-header">
            <img src="https://www.mscloudlogos.com/favicon.ico" alt="" width="32" height="32" class="aussie-logo" />
            <h3>Microsoft Cloud Logos</h3>
          </div>
          <p>
            The quick link icons would not be possible without <strong>Loryan Strant's</strong>
            comprehensive collection of all Microsoft logos and icons at
            <strong>mscloudlogos.com</strong>.
          </p>
          <span class="aussie-link">View on GitHub &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- More from Merill -->
  <section class="merill-section">
    <div class="container">
      <div class="merill-header">
        <h2>More from Merill</h2>
        <p>Other free tools and resources for the Microsoft community.</p>
      </div>
      <div class="merill-grid">
        <a href="https://cmd.ms" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/cmdms.png" alt="" width="32" height="32" class="merill-logo" />
          <h3>cmd.ms</h3>
          <p>The Microsoft Cloud command line. Jump to any portal from your browser address bar.</p>
        </a>
        <a href="https://entra.news" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/entranews-64.png" alt="" width="32" height="32" class="merill-logo" />
          <h3>Entra News</h3>
          <p>Weekly newsletter covering the latest Microsoft Entra and identity news.</p>
        </a>
        <a href="https://entra.chat" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/entrachat-64.png" alt="" width="32" height="32" class="merill-logo" />
          <h3>Entra Chat</h3>
          <p>A weekly podcast covering the latest Microsoft Entra and identity news.</p>
        </a>
        <a href="https://graphxray.merill.net" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/graphxray.png" alt="" width="32" height="32" class="merill-logo" />
          <h3>Graph X-Ray</h3>
          <p>See the Microsoft Graph API calls behind every click in the Azure and Entra portals.</p>
        </a>
        <a href="https://maester.dev" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/maester.ico" alt="" width="32" height="32" class="merill-logo" />
          <h3>Maester</h3>
          <p>Automated testing framework for your Microsoft 365 tenant security configuration.</p>
        </a>
        <a href="https://lokka.dev" class="merill-card" rel="noreferrer noopener">
          <img src="/logos/lokka.ico" alt="" width="32" height="32" class="merill-logo" />
          <h3>Lokka</h3>
          <p>The first MCP Server for Microsoft Graph. Built for agentic AI workloads.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-container">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>
              <span>{faq.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            </summary>
            <p set:html={faq.a} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container final-cta-inner">
      <img src="/favicon-128x128.png" alt="Yako" width="64" height="64" class="cta-icon" />
      <h2>Ready to try Yako?</h2>
      <p>Start navigating Microsoft portals faster. Free, open source, and private.</p>
      <a href="/docs/install/" class="btn btn-primary">Install for free</a>
      <p class="cta-trust">Free forever &middot; Open source &middot; No account required</p>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  /* ========================================
     Hero
     ======================================== */
  .hero {
    padding-top: 24px;
    padding-bottom: 24px;
  }

  @media (min-width: 640px) {
    .hero {
      padding-top: 40px;
      padding-bottom: 40px;
    }
  }

  .hero-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 8px;
  }

  @media (min-width: 640px) {
    .hero-container {
      padding: 0 24px;
    }
  }

  .hero-bg {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    border-radius: 24px 24px 8px 8px;
    background-size: cover;
    background-position: center;
    padding: 24px 16px 96px;
  }

  @media (min-width: 640px) {
    .hero-bg {
      padding: 64px 64px 112px;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: -1px;
    border-radius: 24px 24px 8px 8px;
    background-color: var(--color-bg);
    opacity: 1;
    transition: opacity 0.7s;
  }

  .hero-overlay.revealed {
    opacity: 0;
  }

  .hero-fade {
    position: absolute;
    inset: -4px -4px -4px -4px;
    bottom: -4px;
    height: 128px;
    pointer-events: none;
    background: linear-gradient(to top, var(--color-bg) 20%, transparent 100%);
    top: auto;
  }

  .hero-card {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    padding: 24px 16px 32px;
    background: var(--color-bg);
    text-align: center;
    transition: background-color 0.7s, backdrop-filter 0.7s, box-shadow 0.7s;
  }

  @media (min-width: 640px) {
    .hero-card {
      padding: 32px 24px 40px;
    }
  }

  .hero-card.revealed {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px);
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.2);
  }

  :global(.dark) .hero-card.revealed {
    background: rgba(9, 9, 11, 0.9);
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
  }

  @media (prefers-color-scheme: dark) {
    :global(:not(.light)) .hero-card.revealed {
      background: rgba(9, 9, 11, 0.9);
      box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
    }
  }

  /* Cursor & selection rect */
  .hero-cursor {
    position: absolute;
    z-index: 20;
    pointer-events: none;
    display: none;
    top: 40%;
    left: 30%;
    opacity: 0;
  }

  .hero-cursor.phase-cursor-in {
    display: block;
    animation: hero-cursor-enter 0.7s ease-out forwards;
  }

  .hero-cursor.phase-selecting {
    display: block;
    animation: hero-cursor-drag 1.2s ease-out forwards;
  }

  .hero-cursor.phase-pause {
    display: block;
    opacity: 1;
    top: calc(100% - 4px);
    left: calc(100% - 4px);
  }

  .hero-select-rect {
    position: absolute;
    z-index: 10;
    pointer-events: none;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border: 2px dashed rgba(59, 130, 246, 0.7);
    border-radius: var(--radius-lg);
    display: none;
  }

  .hero-select-rect.phase-selecting {
    display: block;
    animation: hero-rect-grow 1.2s ease-out forwards;
  }

  .hero-select-rect.phase-pause {
    display: block;
    width: 100%;
    height: 100%;
  }

  @keyframes hero-cursor-enter {
    0%   { opacity: 0; top: 40%; left: 30%; }
    40%  { opacity: 1; }
    100% { opacity: 1; top: -4px; left: -4px; }
  }

  @keyframes hero-cursor-drag {
    0%   { opacity: 1; top: -4px; left: -4px; }
    100% { opacity: 1; top: calc(100% - 4px); left: calc(100% - 4px); }
  }

  @keyframes hero-rect-grow {
    0%   { width: 0; height: 0; top: 0; left: 0; }
    100% { width: 100%; height: 100%; top: 0; left: 0; }
  }

  .hero-card h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    margin-top: 24px;
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 40px;
    align-items: center;
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .hero-actions .btn {
    padding: 14px 24px;
    border-radius: var(--radius);
    font-size: 0.9rem;
  }

