<script>
  const BACKGROUNDS = [
    '/landing/hero-bg.webp',
    '/landing/hero-bg-2.webp',
    '/landing/hero-bg-3.webp',
    '/landing/hero-bg-4.webp',
    '/landing/hero-bg-5.webp',
  ]

  const heroBg = document.getElementById('hero-bg')
  const overlay = document.getElementById('hero-overlay')
  const card = document.getElementById('hero-card')
  const cursor = document.getElementById('hero-cursor')
  const rect = document.getElementById('hero-rect')

  let timeouts = []
  let currentIndex = 0
  let wasOffscreen = false
  let imagesLoaded = false

  function clearAll() {
    timeouts.forEach(clearTimeout)
    timeouts = []
  }

  function schedule(fn, delay) {
    timeouts.push(setTimeout(fn, delay))
  }

  function setPhase(phase) {
    // Cursor classes
    cursor.className = 'hero-cursor'
    rect.className = 'hero-select-rect'

    if (phase === 'cursor-in' || phase === 'selecting' || phase === 'pause') {
      cursor.classList.add('phase-' + phase)
      if (phase === 'selecting' || phase === 'pause') {
        rect.classList.add('phase-' + phase)
      }
    }

    // Overlay + card reveal
    const revealed = phase === 'beautifying' || phase === 'done'
    overlay.classList.toggle('revealed', revealed)
    card.classList.toggle('revealed', revealed)
  }

  function runAnimation() {
    schedule(() => setPhase('cursor-in'), 100)
    schedule(() => setPhase('selecting'), 900)
    schedule(() => setPhase('pause'), 2100)
    schedule(() => setPhase('beautifying'), 2600)
    schedule(() => {
      setPhase('done')
      schedule(() => startCycle(true), 2000)
    }, 3400)
  }

  function startCycle(advance) {
    clearAll()
    setPhase('idle')

    if (advance) {
      schedule(() => {
        currentIndex = (currentIndex + 1) % BACKGROUNDS.length
        heroBg.style.backgroundImage = "url('" + BACKGROUNDS[currentIndex] + "')"
        runAnimation()
      }, 800)
    } else {
      runAnimation()
    }
  }

  // Preload images, start when first loads
  BACKGROUNDS.forEach((src, i) => {
    const img = new Image()
    img.src = src
    img.onload = () => {
      if (i === 0 && !imagesLoaded) {
        imagesLoaded = true
        startCycle(false)
      }
    }
    img.onerror = () => {
      if (i === 0) setPhase('done')
    }
  })

  // Pause when offscreen, restart when visible
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        if (wasOffscreen && imagesLoaded) {
          wasOffscreen = false
          startCycle(true)
        }
      } else {
        wasOffscreen = true
        clearAll()
      }
    },
    { threshold: 0.3 },
  )
  observer.observe(heroBg)
</script>
