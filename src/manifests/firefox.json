{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "short_name": "Yako",
    "version": "1.0.0",
    "description": "__MSG_extensionDesc__",
    "author": "Merill Fernando",
    "homepage_url": "https://getyako.com",
    "default_locale": "en",
    "icons": {
        "128": "src/assets/favicons/favicon-128x128.png"
    },
    "chrome_settings_overrides": {
        "homepage": "index.html"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "action": {
        "default_icon": {
            "128": "src/assets/favicons/favicon-128x128.png"
        },
        "default_title": "__MSG_extensionName__"
    },
    "background": {
        "scripts": [
            "src/scripts/service-worker.js"
        ]
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://services.bonjourr.fr/*",
        "https://getyako.com/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{579125a9-456a-4d39-8f8e-fb273fe52ea0}",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
